{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/aid-hook\" session-start",
            "timeout": 10,
            "statusMessage": "Registering AID session"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/aid-hook\" user-prompt-submit",
            "timeout": 10,
            "statusMessage": "Recording AID goal"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/aid-hook\" pre-tool-use",
            "timeout": 10,
            "statusMessage": "Checking AID operation chain"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Read|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/aid-hook\" post-tool-use",
            "timeout": 10,
            "statusMessage": "Recording AID trace"
          }
        ]
      }
    ]
  }
}
