{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/hooks/aid-hook session-start",
            "timeout": 5,
            "statusMessage": "Registering AID session..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/hooks/aid-hook user-prompt-submit",
            "timeout": 5,
            "statusMessage": "Recording AID goal..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Task|Bash|Shell|exec_command|functions\\.exec_command|apply_patch|ApplyPatch|Read|Write|Edit|MultiEdit|NotebookEdit|Grep|Glob|LS|WebFetch|WebSearch|TodoWrite|update_plan|spawn_agent|send_input|wait_agent|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/hooks/aid-hook pre-tool-use",
            "timeout": 10,
            "statusMessage": "Checking AID operation chain..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task|Bash|Shell|exec_command|functions\\.exec_command|apply_patch|ApplyPatch|Read|Write|Edit|MultiEdit|NotebookEdit|Grep|Glob|LS|WebFetch|WebSearch|TodoWrite|update_plan|spawn_agent|send_input|wait_agent|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/hooks/aid-hook post-tool-use",
            "timeout": 10,
            "statusMessage": "Recording AID trace..."
          }
        ]
      }
    ]
  }
}
