{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/hooks/aid-hook session-start",
            "timeout": 5,
            "statusMessage": "Registering AID session..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/hooks/aid-hook user-prompt-submit",
            "timeout": 5,
            "statusMessage": "Recording AID goal..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/hooks/aid-hook pre-tool-use",
            "timeout": 10,
            "statusMessage": "Checking AID operation chain..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/hooks/aid-hook post-tool-use",
            "timeout": 10,
            "statusMessage": "Recording AID trace..."
          }
        ]
      }
    ]
  }
}
